{
  "name": "@jamadd/react-native-template-ui",
  "version": "0.8.2",
  "description": "React Native Template UI is a collection of UI components designed by JaMa D&D.",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example-clean": "yarn example clean && yarn && yarn example prebuild",
    "example": "yarn workspace react-native-template-ui-example",
    "test": "jest",
    "test-snapshot": "jest --updateSnapshot",
    "test-watch": "jest --watch",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli lib && rm -rf node_modules && yarn",
    "prepare": "bob build",
    "release": "release-it --only-version",
    "release-major": "yarn prepare && node scripts/bumpVersion.js major && yarn release-commit",
    "release-minor": "yarn prepare && node scripts/bumpVersion.js minor && yarn release-commit",
    "release-patch": "yarn prepare && node scripts/bumpVersion.js patch && yarn release-commit",
    "release-commit": "git add . && git commit -m \"v${npm_package_version}\" && git tag v${npm_package_version} && git push origin main --tags"
  },
  "keywords": [
    "reactnativetemplate",
    "react native template",
    "rnt",
    "react-native-template",
    "jamadd",
    "jamad&d",
    "jama",
    "ui library",
    "ui components",
    "ui package",
    "ui",
    "react-native",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JaMaDD/react-native-template-ui.git"
  },
  "author": "JaMaD&D <jameswaitingontheday@gmail.com> (https://reactnativetemplate.com)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/JaMaDD/react-native-template-ui/issues"
  },
  "homepage": "https://github.com/JaMaDD/react-native-template-ui",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@jamadd/react-native-template-icons": "^0.4.8",
    "@jest/globals": "^30.0.0",
    "@react-native/babel-preset": "0.85.0",
    "@react-native/eslint-config": "^0.85.0",
    "@react-native/jest-preset": "0.85.0",
    "@release-it/conventional-changelog": "^10.0.6",
    "@shopify/flash-list": "^2.3.1",
    "@shopify/restyle": "^2.4.5",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-test-renderer": "19.1.0",
    "babel-plugin-react-compiler": "1.0.0",
    "del-cli": "^7.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ft-flow": "^3.0.11",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-testing-library": "^7.8.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "react": "19.2.3",
    "react-native": "0.85.0",
    "react-native-builder-bob": "^0.41.0",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-worklets": "^0.8.1",
    "react-test-renderer": "19.2.3",
    "release-it": "^19.2.4",
    "turbo": "^2.8.21",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "@jamadd/react-native-template-icons": ">=0.4.8",
    "@shopify/flash-list": ">=2.3.1",
    "@shopify/restyle": ">=2.4.5",
    "react": ">=19.2.3",
    "react-native": ">=0.85.0",
    "react-native-gesture-handler": ">=2.31.1",
    "react-native-reanimated": ">=4.3.0",
    "react-native-safe-area-context": ">=5.7.0",
    "react-native-worklets": ">=0.8.1"
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "jest": {
    "preset": "@react-native/jest-preset",
    "setupFiles": [
      "<rootDir>/src/test/__mocks__/jestSetup.js",
      "<rootDir>/node_modules/react-native-gesture-handler/jestSetup.js"
    ],
    "transformIgnorePatterns": [
      "<rootDir>/node_modules/(?!(jest-)?react-native|@react-native|react-native-reanimated)"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ],
    "moduleNameMapper": {
      "\\.(ttf)$": "<rootDir>/src/test/__mocks__/file-mock.js"
    }
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  },
  "create-react-native-library": {
    "type": "library",
    "languages": "js",
    "tools": [
      "eslint",
      "jest",
      "release-it"
    ],
    "version": "0.61.0"
  }
}
